#!/bin/bash
# fruitbang-menu — rofi launcher
# designed by mrgreen [mrgreen@archbang.org]

items="Terminal\0icon\x1futilities-terminal\nBrowser\0icon\x1fapplications-internet\nFiles\0icon\x1fsystem-file-manager\nApplications\0icon\x1fsystem-run\nGuide\0icon\x1fhelp-contents\nKeybinds\0icon\x1finput-keyboard\nExit\0icon\x1fsystem-shutdown"

choice=$(printf "$items" | rofi -dmenu -p "FruitBang" -show-icons \
  -theme-str "listview {lines: 7;} inputbar { enabled: false; } window { width: 250px; }")

case "$choice" in
  Terminal)
    foot
    ;;
  Browser)
    chromium
    ;;
  Files)
    foot -e lf
    ;;
  Applications)
    rofi -show drun
    ;;
  Guide)
    foot -e nvim ~/Documents/Guide
    ;;
  Keybinds)
    grep -E "(Super|Ctrl|Vol|Mute|Alt)" ~/Documents/Keybindings \
      | rofi -dmenu -p "Keybinds" -columns 2 -theme-str "listview {lines: 16;}"
    ;;
  Exit)
    ~/Scripts/powermenu
    ;;
esac
