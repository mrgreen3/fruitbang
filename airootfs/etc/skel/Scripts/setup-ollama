#!/bin/bash
# setup-ollama — install Ollama and run a cloud model (no local weights)

set -e

echo "=== Ollama Setup ==="
echo

if ! command -v ollama &>/dev/null; then
    echo "Installing Ollama..."
    sudo pacman -Sy --noconfirm ollama
else
    echo "Ollama already installed: $(ollama --version)"
fi

echo
echo "=== Pick a cloud model ==="
echo "No download — runs via Ollama cloud inference:"
echo "  1) kimi-k2.7-code:cloud"
echo "  2) glm-5.2:cloud"
echo "  3) gemma4:cloud"
echo "  4) qwen3.5:cloud"
echo "  5) Enter manually"
echo
read -rp "Choice [1-5]: " choice

case "$choice" in
    1) model="kimi-k2.7-code:cloud" ;;
    2) model="glm-5.2:cloud" ;;
    3) model="gemma4:cloud" ;;
    4) model="qwen3.5:cloud" ;;
    5) read -rp "Model name: " model ;;
    *) echo "Invalid. Run 'ollama run <model>:cloud' manually."; exit 1 ;;
esac

echo
ollama run "$model"
