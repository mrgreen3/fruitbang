#!/bin/bash
# Install yay AUR helper from source

set -e

echo "Checking network..."
if ! curl -s --connect-timeout 5 https://archlinux.org >/dev/null 2>&1; then
    echo "No network connection. Connect first and retry."
    exit 1
fi

if command -v yay >/dev/null 2>&1; then
    echo "yay already installed: $(yay --version)"
    exit 0
fi

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

echo "Cloning yay..."
git clone https://aur.archlinux.org/yay.git "$TMP/yay"

echo "Building and installing yay..."
cd "$TMP/yay"
makepkg -si --noconfirm

echo "yay installed: $(yay --version)"
