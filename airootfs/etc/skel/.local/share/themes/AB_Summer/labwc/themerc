# AB_Summer theme configuration for labwc
# Beach palette from ~/Backgrounds/beach.jpg

border.width: 3

window.active.border.color: #87C8E8
window.inactive.border.color: #00000000

# RRGGBBAA: menu-highlight blue at 95% opacity
window.active.title.bg.color: #87C8E8F2
window.inactive.title.bg.color: #D8EEF833
window.*.title.bg: Solid

window.active.label.text.color: #1a1a1a
window.inactive.label.text.color: #1a1a1a
window.label.text.justify: left

window.button.width: 26
window.button.height: 26
window.button.spacing: 0

# storm cloud buttons
window.active.button.iconify.unpressed.image.color: #1a1a1a
window.active.button.iconify.pressed.image.color: #1a1a1a
window.active.button.iconify.hover.image.color: #5A6A80

window.active.button.max.unpressed.image.color: #1a1a1a
window.active.button.max.pressed.image.color: #1a1a1a
window.active.button.max.hover.image.color: #5A6A80

window.active.button.close.unpressed.image.color: #1a1a1a
window.active.button.close.pressed.image.color: #1a1a1a
window.active.button.close.hover.image.color: #5A6A80

window.inactive.button.unpressed.image.color: #7AAEC099

window.active.shadow.size: 60
window.inactive.shadow.size: 30
window.active.shadow.color: #00000022
window.inactive.shadow.color: #00000011

menu.items.bg.color: #D8EEF8CC
menu.items.text.color: #1a1a1a
menu.items.active.bg.color: #87C8E8CC
menu.items.active.text.color: #1a1a1a
menu.border.color: #87C8E8
menu.border.width: 0

menu.overlap.x: -5
menu.overlap.y: 0

osd.bg.color: #D8EEF8
osd.border.color: #87C8E8
osd.border.width: 1
osd.label.text.color: #1a1a1a
