#!/bin/bash
# wmenu launcher with Summer theme colors

# Summer colors (from beach.jpg palette)
BG_NORMAL="#D8EEF8"      # shallow water background
FG_NORMAL="#1A3550"      # deep navy text
BG_SELECTED="#87C8E8"    # sky blue selection
FG_SELECTED="#1A3550"    # deep navy text on selection

# Launch wmenu with Summer theme
wmenu-run \
	-N "$BG_NORMAL" \
	-n "$FG_NORMAL" \
	-M "$BG_NORMAL" \
	-m "$FG_NORMAL" \
	-S "$BG_SELECTED" \
	-s "$FG_SELECTED" \
	-p " " \
	"$@"
