#!/bin/bash
# wmenu launcher with Seafront-Storm theme colors

# Seafront-Storm colors (from labwc theme)
BG_NORMAL="#D8EEF8"      # main background
FG_NORMAL="#1A3550"      # light text
BG_SELECTED="#87C8E8"    # sky blue selection
FG_SELECTED="#1A3550"    # dark text on selection

# Launch wmenu with Storm theme
wmenu-run \
	-N "$BG_NORMAL" \
	-n "$FG_NORMAL" \
	-M "$BG_NORMAL" \
	-m "$FG_NORMAL" \
	-S "$BG_SELECTED" \
	-s "$FG_SELECTED" \
	-p " " \
	"$@"
