{
  "layer": "top",
  "position": "bottom",
  "height": 30,
  "spacing": 4,
  "modules-left": [
    "ext/workspaces"
  ],
  "modules-center": [
    "custom/terminal",
    "custom/browser",
    "custom/launcher",
    "custom/files",
    "custom/editor"
  ],
  "modules-right": [
    // "pulseaudio",
    "tray",
    "battery",
    "clock"
  ],
  "ext/workspaces": {
    "format": "{id}",
    "on-click": "activate",
    "sort-by-id": true,
    "all-outputs": true
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%A %d}</big>\n<tt>{calendar}</tt>",
    "calendar": {
        "mode": "month",
        "weeks-pos": "right",
        "on-scroll": 1
    },
    "interval": 60
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "󰖁 {volume}%",
    "format-icons": ["󰕿", "󰖀", "󰕾"],
    "on-click": "pavucontrol"
  },
  "custom/terminal": {
    "format": "",
    "on-click": "foot",
    "tooltip": false
  },
  "custom/browser": {
    "format": "",
    "on-click": "firefox",
    "tooltip": false
  },
  "custom/launcher": {
    "format": "",
    "on-click": "rofi -show drun",
    "tooltip": false
  },
  "custom/files": {
    "format": "",
    "on-click": "thunar",
    "tooltip": false
  },
  "custom/editor": {
    "format": "",
    "on-click": "l3afpad",
    "tooltip": false
  },
  "battery": {
    "format": "{icon}",
    "format-charging": "󰂄",
    "format-full": "󰁹",
    "format-unknown": "",
    "format-icons": ["󰁻", "󰁼", "󰁽", "󰁾", "󰁿"],
    "states": {
      "warning": 30,
      "critical": 15
    },
    "tooltip-format": "{capacity}% · {time} remaining · {power}W"
  }
}
